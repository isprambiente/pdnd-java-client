<?xml version="1.0" encoding="UTF-8"?>
<toolchains xmlns="http://maven.apache.org/TOOLCHAINS/1.1.0"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://maven.apache.org/TOOLCHAINS/1.1.0
                                https://maven.apache.org/xsd/toolchains-1.1.0.xsd">

  <!-- JDK 21 -->
  <toolchain>
    <type>jdk</type>
    <provides>
      <version>21</version>
      <vendor>temurin</vendor>
    </provides>
    <configuration>
      <jdkHome>/opt/hostedtoolcache/temurin/21/*/x64</jdkHome>
    </configuration>
  </toolchain>

  <!-- JDK 25 -->
  <toolchain>
    <type>jdk</type>
    <provides>
      <version>25</version>
      <vendor>temurin</vendor>
    </provides>
    <configuration>
      <jdkHome>/opt/hostedtoolcache/temurin/25/*/x64</jdkHome>
    </configuration>
  </toolchain>

</toolchains>
